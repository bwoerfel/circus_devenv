{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: drive_simulator_node",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/ca1_motor_ctrl/drive_simulator_node",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "/opt/ros/humble/lib:${workspaceFolder}/build/ca1_motor_ctrl"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "colcon: build"
    },
    {
      "name": "Debug: drive_controller",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/ca1_motor_ctrl/drive_controller",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "/opt/ros/humble/lib:${workspaceFolder}/build/ca1_motor_ctrl"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "colcon: build"
    }
  ]
}
